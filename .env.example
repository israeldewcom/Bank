# Chronos v5.2 Environment Variables Example
# Copy to .env and fill in secure values

# Core
CHRONOS_ENV=production
CHRONOS_API_KEY=your-strong-api-key-here
SECRET_KEY=your-strong-secret-key-at-least-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://chronos:password@localhost:5432/chronos
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# NIBSS
NIBSS_API_KEY=your-nibss-key

# Market Data (choose one or more)
BLOOMBERG_API_KEY=your-bloomberg-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
YAHOO_FINANCE_ENABLED=true

# Advanced Features
ADVANCED_FEATURES_ENABLED=true
BACKFILL_TRAINING_ENABLED=true
BACKFILL_CSV_PATH=./historical_settlements.csv

# Security
HSM_ENABLED=false
ENCRYPT_SENSITIVE_FIELDS=true

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE=chronos.log

# Performance
ASYNC_DB=true
CACHE_ENABLED=true

# Backup
DB_BACKUP_ENABLED=true
DB_BACKUP_PATH=/backups
